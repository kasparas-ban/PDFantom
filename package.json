{
  "name": "pdfantom",
  "productName": "PDFantom",
  "version": "0.1.0",
  "private": true,
  "description": "A secure, local-first macOS textbook reader",
  "main": ".vite/build/main.js",
  "scripts": {
    "start": "electron-forge start",
    "build": "vite build --config vite.main.config.ts && vite build --config vite.preload.config.ts && vite build --config vite.renderer.config.ts",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && playwright test",
    "test:app": "playwright test"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "pdfjs-dist": "6.0.227",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "7.11.2",
    "@electron-forge/maker-zip": "7.11.2",
    "@electron-forge/plugin-vite": "7.11.2",
    "@playwright/test": "1.61.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "24.0.14",
    "@types/pngjs": "6.0.5",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "electron": "42.5.0",
    "pdf-lib": "1.17.1",
    "pngjs": "7.0.0",
    "tailwindcss": "^4.3.1",
    "typescript": "7.0.2",
    "vite": "8.1.0"
  }
}
